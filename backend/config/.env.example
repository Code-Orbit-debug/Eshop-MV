# Copy to backend/config/.env for local development
# On Railway, set these as environment variables in the dashboard

PORT=8000
NODE_ENV=development

# MongoDB connection string
DB_URL=mongodb://localhost:27017/eshop-mv

# JWT
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_EXPIRES=7d
ACTIVATION_SECRET=your_activation_secret_here

# SMTP (Gmail example — works locally; blocked on Railway Hobby/Free plans)
SMTP_SERVICE=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_MAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# Resend (recommended for Railway Hobby/Free — uses HTTPS, not blocked)
# Sign up at https://resend.com and verify your domain or use onboarding@resend.dev for testing
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM=onboarding@resend.dev

# Stripe
STRIPE_API_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Cloudinary
CLOUDINARY_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend URL for CORS (required in production)
FRONTEND_URL=https://eshop-mv.vercel.app
